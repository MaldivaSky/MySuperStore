# Variáveis de produção — usadas pelo Vercel no build
# NÃO commitar se contiver segredos — este arquivo é seguro pois só tem variáveis NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=https://mysuperstore-production-667b.up.railway.app/api/v1
# Identificador de conta do Efí (painel → API → "Identificador de Conta").
# OBRIGATÓRIO para tokenizar cartão no checkout (Efí.js). Sem isto, o cartão não funciona.
NEXT_PUBLIC_EFI_ACCOUNT_IDENTIFIER=
NEXT_PUBLIC_IS_DEBUG=false
