# =============================================================================
# MySuperStore — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores ANTES de rodar o projeto
# NUNCA commite o .env — ele está no .gitignore
# =============================================================================

# --- Django -------------------------------------------------------------------
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=GERE_UMA_CHAVE_ALEATORIA_AQUI
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Banco de dados -----------------------------------------------------------
POSTGRES_DB=mysuperstore
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/mysuperstore

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Celery -------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- E-mail (Gmail) -----------------------------------------------------------
# IMPORTANTE: Use uma "Senha de App" do Google (não sua senha normal)
# Acesse: myaccount.google.com/apppasswords
# Os nomes abaixo são os que o settings realmente lê (MAIL_*).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=SENHA_DE_APP_16_CHARS
MAIL_DEFAULT_SENDER=MySuperStore <seu-email@gmail.com>
# Base usada nos links de confirmação enviados por e-mail
FRONTEND_URL=http://localhost:3000

# --- Stripe (pagamentos + Connect split) --------------------------------------
# Use SEMPRE chaves de TESTE em desenvolvimento: https://dashboard.stripe.com/test/apikeys
# As chaves de teste começam com sk_test_ / pk_test_ e NÃO movem dinheiro real.
STRIPE_SECRET_KEY=sk_test_SUBSTITUA
STRIPE_PUBLIC_KEY=pk_test_SUBSTITUA
# Webhook Secret: gerado por `stripe listen --forward-to localhost:8000/api/v1/payments/webhook/`
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUA

# --- Meilisearch --------------------------------------------------------------
MEILI_MASTER_KEY=devmasterkey
MEILI_HOST=http://meilisearch:7700

# --- Cloudflare R2 / AWS S3 (mídia em produção) -------------------------------
# Deixe em branco para usar armazenamento local em desenvolvimento
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=mysuperstore-media
AWS_S3_ENDPOINT_URL=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_CUSTOM_DOMAIN=

# --- Sentry (monitoramento de erros em produção) ------------------------------
SENTRY_DSN=

# --- Frontend (Next.js) -------------------------------------------------------
# Defina também em frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_SUBSTITUA

# --- Efí Bank (PIX Recebimentos) ----------------------------------------------
# Credenciais em https://app.efipay.com.br → API → Minhas Aplicações
# Coloque os valores REAIS apenas no .env (este arquivo é versionado!).
# EFI_ENV: "sandbox" (homologação) ou "production"
EFI_ENV=sandbox
EFI_CLIENT_ID_HOMOL=Client_Id_SUBSTITUA
EFI_CLIENT_SECRET_HOMOL=Client_Secret_SUBSTITUA
EFI_CLIENT_ID_PROD=Client_Id_SUBSTITUA
EFI_CLIENT_SECRET_PROD=Client_Secret_SUBSTITUA
# Caminho para os certificados mTLS .p12 (mantidos FORA do git)
EFI_CERT_HOMOL=SuperStore/Documents/homologacao.p12
EFI_CERT_PROD=SuperStore/Documents/producao.p12
# Chave PIX da conta Efí da plataforma (recebedora)
EFI_PIX_KEY=
