# =============================================================================
# MySuperStore — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores ANTES de rodar o projeto
# NUNCA commite o .env — ele está no .gitignore
# =============================================================================

# --- Django -------------------------------------------------------------------
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=GERE_UMA_CHAVE_ALEATORIA_AQUI
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Banco de dados -----------------------------------------------------------
POSTGRES_DB=mysuperstore
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/mysuperstore

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Celery -------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- E-mail (Gmail) -----------------------------------------------------------
# IMPORTANTE: Use uma "Senha de App" do Google (não sua senha normal)
# Acesse: myaccount.google.com/apppasswords
# REVOGAR a senha exposta no código antigo antes de gerar uma nova
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=SENHA_DE_APP_16_CHARS
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=MySuperStore <seu-email@gmail.com>

# --- Mercado Pago -------------------------------------------------------------
# IMPORTANTE: REVOGAR O TOKEN ANTIGO no painel do Mercado Pago antes de usar
# Painel: https://www.mercadopago.com.br/developers/panel
# Use credenciais de SANDBOX para desenvolvimento
MP_ACCESS_TOKEN=TEST-SUBSTITUA-PELO-SEU-TOKEN-SANDBOX
MP_PUBLIC_KEY=TEST-SUBSTITUA-PELA-SUA-PUBLIC-KEY-SANDBOX
# Webhook Secret: gerado ao configurar webhook no painel MP
MP_WEBHOOK_SECRET=SUBSTITUA_PELO_WEBHOOK_SECRET

# --- Meilisearch --------------------------------------------------------------
MEILI_MASTER_KEY=devmasterkey
MEILI_HOST=http://meilisearch:7700

# --- Cloudflare R2 / AWS S3 (mídia em produção) -------------------------------
# Deixe em branco para usar armazenamento local em desenvolvimento
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=mysuperstore-media
AWS_S3_ENDPOINT_URL=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_CUSTOM_DOMAIN=

# --- Sentry (monitoramento de erros em produção) ------------------------------
SENTRY_DSN=

# --- Frontend (Next.js) -------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-SUBSTITUA-PELA-SUA-PUBLIC-KEY-SANDBOX
